{
  "name": "pi-lark-hub",
  "version": "0.1.0",
  "description": "Pi coding agent multi-Pi Feishu remote control — pi-lark-hub + lark-bridge (register, route, task_end, approval, need_reply, optional lark-cli).",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "feishu",
    "lark",
    "multi-pi",
    "hub",
    "extension",
    "remote"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Happier-X/pi-lark-hub.git"
  },
  "bugs": {
    "url": "https://github.com/Happier-X/pi-lark-hub/issues"
  },
  "homepage": "https://github.com/Happier-X/pi-lark-hub#readme",
  "bin": {
    "pi-lark-hub": "./scripts/pi-lark-hub.mjs"
  },
  "files": [
    "src",
    "scripts",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "node --check src/index.ts || true",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/hub/router.test.ts src/hub/config.test.ts src/hub/feishu-lark-cli.test.ts src/lark-bridge/hub-autostart.test.ts",
    "hub": "tsx src/hub/cli.ts",
    "prepublishOnly": "npm run typecheck"
  },
  "dependencies": {
    "tsx": "^4.20.3",
    "ws": "^8.18.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
